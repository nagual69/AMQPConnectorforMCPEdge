# RabbitMQ URL used by integration tests.
# Override this in your local .env.local if needed.
AMQP_INTEGRATION_URL=amqp://mcp:discovery@127.0.0.1:5672

# RabbitMQ URL used by the end-to-end example.
# If omitted by tooling, scripts may fall back to AMQP_INTEGRATION_URL.
AMQP_EXAMPLE_URL=amqp://mcp:discovery@127.0.0.1:5672
